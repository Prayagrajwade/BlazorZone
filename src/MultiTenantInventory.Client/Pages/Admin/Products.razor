@page "/products"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api

<div class="page-header">
    <div>
        <h1>Products</h1>
        <p>Manage your product inventory</p>
    </div>
    <button class="btn btn-primary" @onclick="() => OpenModal()">+ New Product</button>
</div>

@if (!string.IsNullOrEmpty(_msg))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_msg</div>
}

@if (_loading)
{
    <div class="loading"><div class="spinner"></div></div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _products)
                {
                    <tr>
                        <td>
                            <div style="font-weight:600; color:var(--text-primary);">@p.Name</div>
                            <div style="font-size:12px; color:var(--text-muted);">@p.Description[..Math.Min(60, p.Description.Length)]</div>
                        </td>
                        <td><span class="badge badge-primary">@p.CategoryName</span></td>
                        <td style="font-weight:700; color:var(--accent-primary);">₹@p.Price.ToString("N2")</td>
                        <td>
                            <span class="badge @(p.StockQuantity < 10 ? "badge-danger" : "badge-success")">
                                @p.StockQuantity units
                            </span>
                        </td>
                        <td>
                            <div class="btn-group">
                                <button class="btn btn-secondary btn-sm" @onclick="() => OpenModal(p)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => Delete(p.Id)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_products.Count == 0)
        {
            <div class="empty-state"><div class="icon">📦</div><h3>No products yet</h3><p>Add your first product.</p></div>
        }
    </div>
}

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>@(_editProduct != null ? "Edit" : "New") Product</h2>
                <button class="modal-close" @onclick="CloseModal">×</button>
            </div>

            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="_form.Name" placeholder="Product name" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <input class="form-control" @bind="_form.Description" placeholder="Brief description" />
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="form-group">
                    <label>Price (₹)</label>
                    <input class="form-control" type="number" step="0.01" @bind="_form.Price" />
                </div>
                <div class="form-group">
                    <label>Stock Qty</label>
                    <input class="form-control" type="number" @bind="_form.StockQuantity" />
                </div>
            </div>
            <div class="form-group">
                <label>Category</label>
                <select class="form-control" @bind="_form.CategoryId">
                    <option value="">Select category...</option>
                    @foreach (var c in _categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductDto> _products = new();
    private List<CategoryDto> _categories = new();
    private bool _loading = true, _saving, _showModal;
    private ProductDto? _editProduct;
    private CreateProductDto _form = new();
    private string? _msg;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var pr = await Api.GetAsync<List<ProductDto>>("api/products");
        _products = pr?.Data ?? new();
        var cr = await Api.GetAsync<List<CategoryDto>>("api/categories");
        _categories = cr?.Data ?? new();
        _loading = false;
    }

    private void OpenModal(ProductDto? p = null)
    {
        _editProduct = p;
        _form = p != null ? new CreateProductDto
        {
            Name = p.Name, Description = p.Description, Price = p.Price,
            StockQuantity = p.StockQuantity, CategoryId = p.CategoryId
        } : new();
        _showModal = true;
    }

    private void CloseModal() { _showModal = false; _editProduct = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.CategoryId == Guid.Empty) return;
        _saving = true; _msg = null;

        if (_editProduct != null)
        {
            var r = await Api.PutAsync<ProductDto>($"api/products/{_editProduct.Id}", new UpdateProductDto
            {
                Name = _form.Name, Description = _form.Description, Price = _form.Price,
                StockQuantity = _form.StockQuantity, CategoryId = _form.CategoryId
            });
            _msg = r?.Success == true ? "Product updated." : r?.Message;
            _isError = r?.Success != true;
        }
        else
        {
            var r = await Api.PostAsync<ProductDto>("api/products", _form);
            _msg = r?.Success == true ? "Product created." : r?.Message;
            _isError = r?.Success != true;
        }

        _saving = false;
        CloseModal();
        await LoadData();
    }

    private async Task Delete(Guid id)
    {
        _msg = null;
        var r = await Api.DeleteAsync<bool>($"api/products/{id}");
        _msg = r?.Success == true ? "Product deleted." : r?.Message;
        _isError = r?.Success != true;
        await LoadData();
    }
}
