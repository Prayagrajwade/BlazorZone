@page "/orders"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1>Orders</h1>
        <p>Review and process customer orders</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(_msg))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_msg</div>
}

@if (_loading)
{
    <div class="loading"><div class="spinner"></div></div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Status</th><th>Date</th><th>Review Options</th></tr>
            </thead>
            <tbody>
                @foreach (var o in _orders)
                {
                    <tr>
                        <td style="font-family:monospace; font-size:12px;">@o.Id.ToString()[..8]...</td>
                        <td style="font-weight:600; color:var(--text-primary);">@o.UserName</td>
                        <td style="font-weight:700; color:var(--accent-primary);">₹@o.TotalAmount.ToString("N2")</td>
                        <td><span class="badge @GetBadge(o.Status)">@o.Status</span></td>
                        <td>@o.CreatedAt.ToString("MMM dd, HH:mm")</td>
                        <td>
                            @if (o.Status == "Pending")
                            {
                                <div class="btn-group">
                                    <button class="btn btn-success btn-sm"
                                            @onclick="@(() => UpdateStatus(o.Id, "Approved"))">
                                        Approve
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => InitiateReject(o.Id)">Reject</button>
                                </div>
                            }
                            else
                            {
                                <select class="form-control" style="width:auto; padding:6px 10px; font-size:12px;"
                                        value="@o.Status"
                                        @onchange="e => UpdateStatus(o.Id, e.Value?.ToString())">
                                    @foreach (var s in _statuses)
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </select>
                            }

                            @if (_rejectingId == o.Id)
                            {
                                <div style="margin-top: 8px; display:flex; gap:8px;">
                                    <input type="text" @bind="_rejectionReason" placeholder="Reason for rejection" class="form-control form-control-sm" />
                                    <button class="btn btn-primary btn-sm" @onclick="ConfirmReject">Confirm</button>
                                    <button class="btn btn-secondary btn-sm" @onclick="CancelReject">Cancel</button>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_orders.Count == 0)
        {
            <div class="empty-state"><div class="icon">🛒</div><h3>No orders</h3></div>
        }
    </div>
}

@code {
    private List<OrderDto> _orders = new();
    private bool _loading = true;
    private string? _msg;
    private bool _isError;

    // Reject Flow
    private Guid? _rejectingId;
    private string _rejectionReason = string.Empty;

    private static readonly string[] _statuses = ["Pending", "Approved", "Rejected", "Processing", "Shipped", "Delivered", "Cancelled"];

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        var r = await Api.GetAsync<List<OrderDto>>("api/orders");
        _orders = r?.Data ?? new();
        _loading = false;
    }

    private async Task UpdateStatus(Guid id, string? status, string? reason = null)
    {
        if (string.IsNullOrEmpty(status)) return;
        
        _msg = null;
        var dto = new UpdateOrderStatusDto { Status = status, RejectionReason = reason };
        var r = await Api.PutAsync<bool>($"api/orders/{id}/status", dto);
        
        _msg = r?.Success == true ? $"Order {id.ToString()[..8]} status updated to {status}." : r?.Message;
        _isError = r?.Success != true;
        
        _rejectingId = null;
        _rejectionReason = string.Empty;
        
        await Load();
    }

    private void InitiateReject(Guid id)
    {
        _rejectingId = id;
        _rejectionReason = string.Empty;
    }

    private void CancelReject()
    {
        _rejectingId = null;
        _rejectionReason = string.Empty;
    }

    private async Task ConfirmReject()
    {
        if (_rejectingId == null) return;
        await UpdateStatus(_rejectingId.Value, "Rejected", _rejectionReason);
    }

    private string GetBadge(string s) => s switch
    {
        "Pending" => "badge-warning",
        "Approved" or "Processing" => "badge-info",
        "Shipped" => "badge-primary",
        "Delivered" => "badge-success",
        "Rejected" or "Cancelled" => "badge-danger",
        _ => "badge-info"
    };
}
