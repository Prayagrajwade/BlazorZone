@page "/set-password"
@inject ApiClient Api
@inject NavigationManager Navigation
@layout MainLayout

<div class="login-container">
    <div class="login-card">
        <h1>Set Password</h1>
        <p class="subtitle">Create your account password</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">⚠️ @_error</div>
        }

        @if (_done)
        {
            <div class="alert alert-success">✅ Password set successfully!</div>
            <button class="btn btn-primary" style="width:100%; justify-content:center;" @onclick='() => Navigation.NavigateTo("/login")'>
                Go to Login
            </button>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>New Password</label>
                    <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="Min 6 characters" />
                    <ValidationMessage For="() => _model.Password" class="validation-message" />
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                    <ValidationMessage For="() => _model.ConfirmPassword" class="validation-message" />
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;" disabled="@_loading">
                    @if (_loading) { <span class="spinner" style="width:18px;height:18px;border-width:2px;"></span> }
                    else { <span>Set Password</span> }
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    private SetPasswordDto _model = new();
    private string? _error;
    private bool _loading;
    private bool _done;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var queryString = uri.Query.TrimStart('?');
        var token = "";
        foreach (var part in queryString.Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "token")
            {
                token = Uri.UnescapeDataString(kv[1]);
                break;
            }
        }
        _model.Token = token;

        if (string.IsNullOrEmpty(_model.Token))
            _error = "Invalid or missing token.";
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _loading = true;

        try
        {
            var response = await Api.PostAsync<AuthResponseDto>("api/auth/set-password", _model);
            if (response?.Success == true && response.Data?.Success == true)
            {
                _done = true;
            }
            else
            {
                _error = response?.Data?.Message ?? response?.Message ?? "Failed to set password.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
