@page "/my-orders"
@attribute [Authorize(Roles = "User,Admin")]
@inject ApiClient Api

<div class="page-header">
    <div>
        <h1>My Orders</h1>
        <p>Your order history</p>
    </div>
</div>

@if (_loading)
{
    <div class="loading"><div class="spinner"></div></div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr><th>Order</th><th>Items</th><th>Total</th><th>Status</th><th>Date</th></tr>
            </thead>
            <tbody>
                @foreach (var o in _orders)
                {
                    <tr>
                        <td style="font-family:monospace; font-size:12px;">@o.Id.ToString()[..8]...</td>
                        <td>
                            @foreach (var i in o.Items)
                            {
                                <div style="font-size:13px;">@i.ProductName × @i.Quantity</div>
                            }
                        </td>
                        <td style="font-weight:700; color:var(--accent-primary);">₹@o.TotalAmount.ToString("N2")</td>
                        <td><span class="badge @GetBadge(o.Status)">@o.Status</span></td>
                        <td>@o.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_orders.Count == 0)
        {
            <div class="empty-state"><div class="icon">📋</div><h3>No orders yet</h3><p>Start shopping!</p></div>
        }
    </div>
}

@code {
    private List<OrderDto> _orders = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var r = await Api.GetAsync<List<OrderDto>>("api/orders");
        _orders = r?.Data ?? new();
        _loading = false;
    }

    private string GetBadge(string s) => s switch
    {
        "Pending" => "badge-warning", "Confirmed" or "Processing" => "badge-info",
        "Shipped" => "badge-primary", "Delivered" => "badge-success",
        "Cancelled" => "badge-danger", _ => "badge-info"
    };
}
